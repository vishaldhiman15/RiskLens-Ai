{
  "name": "stocksage",
  "version": "1.0.0",
  "description": "AI-Powered Stock Analysis Platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "install:python": ".venv\\Scripts\\pip.exe install -r python-ai\\requirements.txt",
    "start:python": ".venv\\Scripts\\python.exe python-ai\\app.py",
    "start:all": "concurrently \"npm run dev\" \"npm run start:python\"",
    "build:mac": "cd electron && npm run build"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "serpapi": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
